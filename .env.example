# ── Eleve API ────────────────────────────────────────────────────────
DJANGO_API_URL=http://localhost:8000
SYSTEM_SA_TOKEN=                        # SA do sistema — resolve escola pelo token WhatsApp

# ── OpenAI ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini               # Agentes e router
OPENAI_MODEL_VISION=gpt-4o             # Análise de imagens
OPENAI_MODEL_AUDIO=whisper-1           # Transcrição de áudio

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── WhatsApp — UazAPI ────────────────────────────────────────────────
UAZAPI_BASE_URL=https://eleve.uazapi.com
UAZAPI_GLOBAL_TOKEN=                   # Token global da instância UazAPI

# ── WhatsApp — Meta Cloud API (opcional) ─────────────────────────────
META_VERIFY_TOKEN=                     # Token de verificação do webhook
META_APP_SECRET=                       # Para validar assinatura HMAC

# ── Comportamento ────────────────────────────────────────────────────
DEBOUNCE_SECONDS=3                     # Espera antes de processar mensagens agrupadas
ENVIRONMENT=development                # development | production
LOG_LEVEL=INFO
